//Aura Components
Code -1 Aura Component (Main .cmp) 
<aura:component controller="MyApexController" implements="flexipage:availableForAllPageTypes">

    <!-- Attributes -->
    <aura:attribute name="message" type="String" default="Hello World"/>
    <aura:attribute name="count" type="Integer" default="0"/>

    <!-- Event Handler (Init) -->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <!-- UI -->
    <lightning:card title="Aura Example">
        <p>{!v.message}</p>
        <p>Count: {!v.count}</p>

        <lightning:button label="Increase" onclick="{!c.handleClick}"/>
    </lightning:card>

</aura:component>

Code -1 Usage
aura:component → root tag
controller → connects Apex class
aura:attribute → variables (like state)
{!v.attribute} → access attribute value
{!c.method} → call JS controller method

//Code 2 Controller JS (Client-side Controller) 
({
    doInit : function(component, event, helper) {
        console.log("Component Initialized");
    },

    handleClick : function(component, event, helper) {
        var count = component.get("v.count");
        count++;
        component.set("v.count", count);
    }
})
Code-2 Usage
Handles UI actions
Uses:
component.get() → for read data
component.set() → for update data

//3. Helper JS (Reusable logic).
({
    helperMethod : function(component) {
        console.log("Helper called");
    }
})
Code-3 Usage.
Used for reusable logic
Called from controller
